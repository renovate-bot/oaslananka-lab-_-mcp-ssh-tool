# Dockerfile for E2E testing mcp-ssh-tool against SSH server
FROM node:20-alpine

WORKDIR /app

# Copy package files first for better layer caching
COPY package*.json ./

# Install dependencies
RUN npm ci

# Copy source and test files
COPY src/ ./src/
COPY test/ ./test/
COPY tsconfig.json ./
COPY tsconfig.test.json ./

# Build TypeScript
RUN npm run build

# Default command runs E2E tests
CMD ["npm", "run", "test:e2e"]
