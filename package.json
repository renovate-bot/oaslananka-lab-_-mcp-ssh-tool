{
  "name": "mcp-ssh-tool",
  "version": "1.3.5",
  "mcpName": "io.github.oaslananka/mcp-ssh-tool",
  "description": "Model Context Protocol (MCP) SSH client server for remote automation",
  "type": "module",
  "main": "dist/index.js",
  "exports": "./dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "mcp.json",
    "server.json",
    "README.md",
    "LICENSE",
    "REGISTRY_SUBMISSION.md",
    "registry"
  ],
  "bin": {
    "mcp-ssh-tool": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json -w",
    "test": "jest --testPathPatterns=unit",
    "test:coverage": "jest --coverage --testPathPatterns=unit",
    "test:integration": "jest --testPathPatterns=integration",
    "test:e2e": "jest --testPathPatterns=e2e",
    "lint": "tsc --noEmit && eslint src/**/*.ts test/**/*.ts",
    "lint:fix": "eslint src/**/*.ts test/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run lint && npm run format:check && npm test && npm run build",
    "e2e:docker": "docker-compose up -d ssh-server && npm run test:e2e",
    "integration:docker": "docker-compose up -d ssh-server && npm run test:integration",
    "docs": "npx typedoc --options typedoc.json",
    "start:http": "node dist/server-http.js",
    "setup:chatgpt": "node scripts/setup-chatgpt.mjs",
    "sync-version": "node scripts/sync-version.mjs",
    "version": "node scripts/sync-version.mjs && git add mcp.json server.json registry/mcp-ssh-tool/mcp.json src/mcp.ts",
    "audit": "npm audit --audit-level=moderate",
    "licenses:check": "license-checker --production --failOn \"GPL;AGPL\"",
    "pack:check": "node scripts/check-package-contents.mjs",
    "changeset": "changeset",
    "changeset:version": "changeset version && npm run sync-version",
    "changeset:publish": "changeset publish"
  },
  "keywords": [
    "mcp",
    "ssh",
    "copilot",
    "automation",
    "remote",
    "model-context-protocol",
    "github-copilot",
    "ssh-client",
    "devops",
    "infrastructure"
  ],
  "author": "Osman Aslan <oaslananka>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka/mcp-ssh-tool.git"
  },
  "homepage": "https://github.com/oaslananka/mcp-ssh-tool#readme",
  "bugs": {
    "url": "https://github.com/oaslananka/mcp-ssh-tool/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "node-ssh": "^13.2.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "hono": "^4.12.12"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@jest/globals": "^30.3.0",
    "@types/node": "^25.5.0",
    "@types/ssh2": "^1.15.5",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.2",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "license-checker": "^25.0.1",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/test/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.test.json",
          "diagnostics": {
            "ignoreCodes": [
              151002
            ]
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/index.ts",
      "!src/server-http.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html",
      "cobertura"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 75,
        "lines": 75,
        "statements": 75
      },
      "src/tools/": {
        "branches": 65,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "test-results",
          "outputName": "junit.xml"
        }
      ]
    ]
  }
}
