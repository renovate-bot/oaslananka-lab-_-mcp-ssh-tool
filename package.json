{
  "name": "mcp-ssh-tool",
  "version": "2.1.1",
  "mcpName": "io.github.oaslananka/mcp-ssh-tool",
  "description": "Model Context Protocol (MCP) SSH client server for remote automation",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "main": "dist/index.js",
  "exports": "./dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "!docs/api",
    "examples",
    "AGENTS.md",
    "ARCHITECTURE.md",
    "SECURITY_DECISIONS.md",
    "MIGRATION.md",
    "mcp.json",
    "server.json",
    "README.md",
    "LICENSE",
    "REGISTRY_SUBMISSION.md",
    "registry"
  ],
  "bin": {
    "mcp-ssh-tool": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json -w",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest --testPathPatterns=unit --runInBand",
    "test:coverage": "jest --coverage --testPathPatterns=unit --runInBand",
    "test:integration": "jest --testPathPatterns=integration --runInBand",
    "test:e2e": "jest --testPathPatterns=e2e --runInBand",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" \"test/**/*.ts\" --fix",
    "lint:staged": "node scripts/run-staged-checks.mjs --lint-only",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.{mjs,cjs}\" \".github/workflows/*.{yml,yaml}\" \".azure/pipelines/*.{yml,yaml}\" \".gitlab-ci.yml\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.{mjs,cjs}\" \".github/workflows/*.{yml,yaml}\" \".azure/pipelines/*.{yml,yaml}\" \".gitlab-ci.yml\"",
    "format:staged": "node scripts/run-staged-checks.mjs",
    "prepare": "node scripts/setup-git-hooks.mjs",
    "prepublishOnly": "npm run check",
    "e2e:docker": "docker compose up -d ssh-server && npm run test:e2e",
    "integration:docker": "docker compose up -d ssh-server && npm run test:integration",
    "docs": "npx typedoc --options typedoc.json",
    "start:http": "node dist/server-http.js",
    "setup:chatgpt": "node scripts/setup-chatgpt.mjs",
    "sync-version": "node scripts/sync-version.mjs",
    "version": "node scripts/sync-version.mjs && git add mcp.json server.json registry/mcp-ssh-tool/mcp.json src/mcp.ts",
    "validate:mcp-metadata": "node scripts/validate-mcp-metadata.mjs",
    "validate:chatgpt-app": "node scripts/validate-chatgpt-app.mjs",
    "audit": "npm audit --audit-level=moderate",
    "licenses:check": "node scripts/check-licenses.mjs",
    "pack:check": "node scripts/check-package-contents.mjs",
    "check:quality": "npm run format:check && npm run lint && npm run typecheck && npm run audit && npm run licenses:check",
    "check:package": "npm run build && npm run sync-version -- --check && npm run validate:mcp-metadata && npm run validate:chatgpt-app && npm run pack:check",
    "check:push": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "check": "npm run check:quality && npm run test:coverage && npm run check:package",
    "hook:pre-commit": "npm run format:staged",
    "hook:pre-push": "npm run check:push",
    "changeset": "changeset",
    "changeset:version": "changeset version && npm run sync-version",
    "changeset:publish": "changeset publish"
  },
  "keywords": [
    "mcp",
    "ssh",
    "copilot",
    "automation",
    "remote",
    "model-context-protocol",
    "github-copilot",
    "ssh-client",
    "devops",
    "infrastructure"
  ],
  "author": "Osman Aslan <oaslananka>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaslananka-lab/mcp-ssh-tool.git"
  },
  "homepage": "https://github.com/oaslananka-lab/mcp-ssh-tool#readme",
  "bugs": {
    "url": "https://github.com/oaslananka-lab/mcp-ssh-tool/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.22.2 || ^24.14.1",
    "npm": "^10.9.2 || ^11.12.1"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "node-ssh": "^13.2.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "express-rate-limit": "^8.5.1",
    "hono": "^4.12.18",
    "ip-address": "^10.2.0",
    "protobufjs": "^7.5.5"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@jest/globals": "^30.3.0",
    "@types/node": "^24.12.2",
    "@types/ssh2": "^1.15.5",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.39.4",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "testEnvironment": "node",
    "testMatch": [
      "<rootDir>/test/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": "tsconfig.test.json",
          "diagnostics": {
            "ignoreCodes": [
              151002
            ]
          }
        }
      ]
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts",
      "!src/index.ts",
      "!src/server-http.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html",
      "cobertura"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 75,
        "lines": 75,
        "statements": 75
      },
      "src/tools/": {
        "branches": 65,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    },
    "reporters": [
      "default",
      [
        "<rootDir>/scripts/junit-reporter.cjs",
        {
          "outputDirectory": "test-results",
          "outputName": "junit.xml"
        }
      ]
    ]
  }
}
