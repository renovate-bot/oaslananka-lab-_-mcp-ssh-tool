# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Optional OpenTelemetry tracing
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=mcp-ssh-tool
OTEL_SERVICE_VERSION=

# SSH security
SSH_MCP_HOST_KEY_POLICY=strict
SSH_MCP_KNOWN_HOSTS_PATH=
SSH_DEFAULT_KEY_DIR=
SSH_MCP_ALLOW_ROOT_LOGIN=false
SSH_MCP_ALLOWED_CIPHERS=

# Policy
SSH_MCP_POLICY_FILE=
SSH_MCP_POLICY_MODE=enforce
SSH_MCP_ALLOW_RAW_SUDO=false
SSH_MCP_ALLOW_DESTRUCTIVE_COMMANDS=false
SSH_MCP_ALLOW_DESTRUCTIVE_FS=false
SSH_MCP_ALLOWED_HOSTS=
SSH_MCP_COMMAND_ALLOW=
SSH_MCP_COMMAND_DENY=
SSH_MCP_PATH_ALLOW_PREFIXES=/tmp,/var/tmp,/home,/Users
SSH_MCP_PATH_DENY_PREFIXES=/etc/sudoers,/etc/shadow,/etc/passwd,/boot,/dev,/proc

# Server runtime
SSH_MCP_MAX_SESSIONS=20
SSH_MCP_SESSION_TTL=900000
SSH_MCP_COMMAND_TIMEOUT=30000
SSH_MCP_MAX_FILE_SIZE=10485760
SSH_MCP_RATE_LIMIT=true
SSH_MCP_RATE_LIMIT_MAX=100
SSH_MCP_RATE_LIMIT_WINDOW_MS=60000

# Streamable HTTP transport
SSH_MCP_HTTP_HOST=127.0.0.1
SSH_MCP_HTTP_PORT=3000
SSH_MCP_HTTP_BEARER_TOKEN_FILE=
SSH_MCP_HTTP_ALLOWED_ORIGINS=http://127.0.0.1,http://localhost
SSH_MCP_ENABLE_LEGACY_SSE=false

# Deprecated compatibility aliases. Prefer SSH_MCP_HOST_KEY_POLICY.
STRICT_HOST_KEY_CHECKING=
SSH_MCP_STRICT_HOST_KEY=

# No-custody remote-agent control plane
SSHAUTOMATOR_REMOTE_AGENT_CONTROL_PLANE=false
PUBLIC_BASE_URL=http://localhost:3000
MCP_RESOURCE_URL=http://localhost:3000/mcp
DATABASE_URL=file:./data/sshautomator.db

# GitHub OAuth identity provider for remote connector mode
AUTH_ALLOWED_GITHUB_IDS=
AUTH_ALLOWED_GITHUB_LOGINS=
AUTH_ALLOW_ALL_USERS=false
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/oauth/callback/github

# Remote OAuth, enrollment, signing, and agent limits
ACCESS_TOKEN_TTL_SECONDS=900
AUTH_CODE_TTL_SECONDS=300
ENROLLMENT_TOKEN_TTL_SECONDS=600
CONTROL_PLANE_SIGNING_KEY_PATH=./data/control-plane-ed25519.json
JWT_SIGNING_KEY_PATH=./data/jwt-ed25519.json
AGENT_WS_PATH=/api/agents/connect
MAX_ACTION_TIMEOUT_SECONDS=120
MAX_OUTPUT_BYTES=200000
OAUTH_DCR_MAX_CLIENTS=100
