# Logging
LOG_LEVEL=info
LOG_FORMAT=plain

# Optional OpenTelemetry tracing
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=mcp-ssh-tool
OTEL_SERVICE_VERSION=

# SSH security
STRICT_HOST_KEY_CHECKING=false
KNOWN_HOSTS_PATH=
SSH_DEFAULT_KEY_DIR=

# Server runtime
SSH_MCP_MAX_SESSIONS=20
SSH_MCP_SESSION_TTL=900000
SSH_MCP_COMMAND_TIMEOUT=30000
SSH_MCP_RATE_LIMIT=true

# Optional compatibility and troubleshooting flags
SSH_MCP_DEBUG=false
SSH_MCP_STRICT_HOST_KEY=false
SSH_MCP_DAEMON=false
SSH_MCP_ONESHOT=false

# HTTP/SSE mode
PORT=3000
